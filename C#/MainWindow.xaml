<Window x:Class="App1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sklep z Wędlinami" Height="700" Width="950"
        Background="#340F2D"> 

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>    
            <RowDefinition Height="Auto"/> 
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F6A40B" Padding="25">
            <TextBlock Text="SKLEP Z WĘDLINAMI" FontSize="36" FontWeight="Bold" 
                       HorizontalAlignment="Center" Foreground="#F20EE7" />
        </Border>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}" Margin="40">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel HorizontalAlignment="Center">
                        <Border BorderBrush="#1a1a1a" BorderThickness="0" Margin="0,0,0,15">
                             <Image Source="{Binding ImagePath}" Width="230" Height="210" Stretch="UniformToFill"/>
                        </Border>
                        
                        <TextBlock Text="{Binding Name}" Foreground="#FFFFFF" FontSize="32" Margin="0,5"/>
                        
                        <TextBlock Text="Ilość" Foreground="#FFFFFF" FontSize="26" Margin="0,5"/>

                        <Border Background="#211818" Width="200" Height="55" Margin="0,10" CornerRadius="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Button Command="{Binding RemoveCommand}" Content="-" 
                                        Background="Transparent" BorderThickness="0" 
                                        Foreground="#FFFFFF" FontSize="30" FontWeight="Bold"/>
                                
                                <TextBlock Grid.Column="1" Text="{Binding Quantity}" 
                                           VerticalAlignment="Center" HorizontalAlignment="Center" 
                                           Foreground="#FFFFFF" FontSize="24" Width="50" TextAlignment="Center"/>
                                
                                <Button Grid.Column="2" Command="{Binding AddCommand}" Content="+" 
                                        Background="Transparent" BorderThickness="0" 
                                        Foreground="#FFFFFF" FontSize="29" FontWeight="Bold"/>
                            </Grid>
                        </Border>

                        <TextBlock Text="{Binding PricePerKg, StringFormat='{}{0:N0}zł'}" 
                                   Foreground="#FFFFFF" FontSize="34" Margin="0,30" HorizontalAlignment="Left"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <StackPanel Grid.Row="2" Margin="0,0,0,40" HorizontalAlignment="Center">
            <TextBlock Text="ŁĄCZNA CENA" Foreground="#FFFFFF" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="{Binding GrandTotal, StringFormat='{}{0:N2} zł'}" 
                       Foreground="#FFFFFF" FontSize="42" FontWeight="Bold" HorizontalAlignment="Center"/>
        </StackPanel>
        
    </Grid>
</Window>